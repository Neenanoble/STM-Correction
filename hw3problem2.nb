              SuperscriptBox[
               RowBox[{"x", "[", "t", "]"}], "2"], "+", 
              SuperscriptBox[
               RowBox[{"y", "[", "t", "]"}], "2"]}], ")"}], 
            RowBox[{"3", "/", "2"}]]], 
          RowBox[{"y", "[", "t", "]"}]}]}], ",", 
        RowBox[{
         RowBox[{"x", "[", "0", "]"}], "==", "inix"}], ",", 
        RowBox[{
         RowBox[{"y", "[", "0", "]"}], "==", "iniy"}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"x", "'"}], "[", "0", "]"}], "==", "inivx"}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"y", "'"}], "[", "0", "]"}], "==", "inivy"}]}], "}"}], ",", 
      
      RowBox[{"{", 
