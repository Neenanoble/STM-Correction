Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"F", "[", 
    RowBox[{"x_", ",", "y_", ",", "t_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{
     FractionBox[
      RowBox[{"-", "\[Mu]e"}], 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["x", "2"], "+", 
         SuperscriptBox["y", "2"]}], ")"}], 
       RowBox[{"3", "/", "2"}]]], 
     RowBox[{"{", 
      RowBox[{"x", ",", "y"}], "}"}]}], "+", 
    RowBox[{"\[Mu]m", 
     RowBox[{"(", 
      RowBox[{
       FractionBox[
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"xm", "[", "t", "]"}], ",", 
           RowBox[{"ym", "[", "t", "]"}]}], "}"}], "-", 
         RowBox[{"{", 
          RowBox[{"x", ",", "y"}], "}"}]}], 
        SuperscriptBox[
         RowBox[{"Norm", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"xm", "[", "t", "]"}], ",", 
             RowBox[{"ym", "[", "t", "]"}]}], "}"}], "-", 
           RowBox[{"{", 
            RowBox[{"x", ",", "y"}], "}"}]}], "]"}], "3"]], "-", 
       FractionBox[
        RowBox[{"{", 
         RowBox[{
          RowBox[{"xm", "[", "t", "]"}], ",", 
          RowBox[{"ym", "[", "t", "]"}]}], "}"}], 
        RowBox[{" ", 
