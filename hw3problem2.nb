Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"tenc", " ", "=", 
   RowBox[{
    RowBox[{"FindRoot", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          SuperscriptBox[
           RowBox[{"x", "[", "t", "]"}], "2"], "+", 
          SuperscriptBox[
           RowBox[{"y", "[", "t", "]"}], "2"]}], "/.", "transfer"}], ")"}], "==", 
       SuperscriptBox["r1", "2"]}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "5", ",", "0", ",", "7"}], "}"}]}], "]"}], "[", 
    RowBox[{"[", 
     RowBox[{"1", ",", "2"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"nm", " ", "=", " ", 
   SqrtBox[
    FractionBox["\[Mu]m", 
     SuperscriptBox["am", "3"]]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{" ", 
  RowBox[{
   RowBox[{"\[Theta]tenc", " ", "=", " ", 
    RowBox[{
     RowBox[{"ArcTan", "[", 
      RowBox[{
       RowBox[{"x", "[", "tenc", "]"}], ",", 
       RowBox[{"y", "[", "tenc", "]"}]}], "]"}], "/.", "transfer"}]}], 
   ";"}]}]}], "Input",
