Cell[BoxData[{
 RowBox[{
  RowBox[{"pfull", "=", 
   RowBox[{"ParametricPlot", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"x", "[", 
          RowBox[{"inix", ",", "iniy", ",", "inivx", ",", "inivy"}], "]"}], 
         "[", "t", "]"}], ",", 
        RowBox[{
         RowBox[{"y", "[", 
          RowBox[{"inix", ",", "iniy", ",", "inivx", ",", "inivy"}], "]"}], 
         "[", "t", "]"}]}], "}"}], "/.", "trajectory"}], ",", 
