Cell[BoxData[
 RowBox[{
  RowBox[{"transfer", "=", 
   RowBox[{
    RowBox[{"NDSolve", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"x", "''"}], "[", "t", "]"}], "==", 
         RowBox[{
          FractionBox[
           RowBox[{"-", "\[Mu]e"}], 
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{
              SuperscriptBox[
               RowBox[{"x", "[", "t", "]"}], "2"], "+", 
              SuperscriptBox[
               RowBox[{"y", "[", "t", "]"}], "2"]}], ")"}], 
            RowBox[{"3", "/", "2"}]]], 
          RowBox[{"x", "[", "t", "]"}]}]}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"y", "''"}], "[", "t", "]"}], "==", 
